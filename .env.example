# Discord webhook for alerts
# Get this from your Discord server webhook settings
DISCORD_WEBHOOK_URL=https://discordapp.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Google Sheets ID
# Extract from the URL: https://docs.google.com/spreadsheets/d/{SHEET_ID}/edit
SHEET_ID=your-sheet-id-here

# Google OAuth credentials (for Vercel deployment)
# Copy the full JSON contents of your credentials.json and token.json files
# From: ~/.openclaw/google/credentials.json
GOOGLE_CREDENTIALS={"installed":{"client_id":"...","client_secret":"...","redirect_uris":["..."]}}
# From: ~/.openclaw/google/token.json
GOOGLE_TOKEN={"access_token":"...","refresh_token":"...","scope":"...","token_type":"Bearer","expiry_date":...}

# Supabase Auth (required for login)
# Get these from your Supabase project: Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Vercel Cron secret (protects the /api/scrape endpoint)
# Generate a random string: openssl rand -hex 32
CRON_SECRET=your-random-secret-here
